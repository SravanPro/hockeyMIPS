   </wvobject>
   <wvobject fp_name="/hockeyTB/DUT/r4" type="array">
      <obj_property name="ElementShortName">r4[31:0]</obj_property>
      <obj_property name="ObjectShortName">r4[31:0]</obj_property>
      <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
