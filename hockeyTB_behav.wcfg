      <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      <obj_property name="CustomSignalColor">#0000FF</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject fp_name="/hockeyTB/DUT/r3" type="array">
      <obj_property name="ElementShortName">r3[31:0]</obj_property>
      <obj_property name="ObjectShortName">r3[31:0]</obj_property>
      <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      <obj_property name="CustomSignalColor">#FFFF00</obj_property>
